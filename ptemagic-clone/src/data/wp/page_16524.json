ậc 5 - Cao Cấp',\n                'TOEIC': 'LR: 945 - SW: 360',\n                'TOEFL iBT': '~ 113 - 120',\n                'Cambridge English': 'CAE',\n                'EF SET': '61 – 70',\n                'CEFR Level': 'C1'\n            },\n            \"86 - 90\": {\n                'IELTS': '9.0',\n                'KNLNN Việt Nam': 'Bậc 6 - Cao Cấp',\n                'TOEIC': null,\n                'TOEFL iBT': null,\n                'Cambridge English': 'CPE',\n                'EF SET': '71 – 200',\n                'CEFR Level': 'C2'\n            },\n        }\n        $('#pte-ielts-convert').on('click','.convert-btn', function(e) {\n            e.preventDefault();\n            const examType = $('#exam-type').val();\n            const scoreResult = $('#score_result').val();\n            if(!examType || !scoreResult){\n                alert('Vui lòng chọn chứng chỉ và kết quả quy đổi');\n                return false;\n            }\n            $('.res-result-diem').show();\n            $('.res-result-diem').html(`<p style=\"margin-bottom: 10px;\"><b>Kết quả quy đổi: </b></p><p class=\"res-result-diem-text\" style=\"margin-bottom: 0;\"><img decoding=\"async\" class=\"no-lazy\" src=\"https://ptemagic.com.vn/wp-content/themes/pte-magic/images/favicon-pte.png\" alt=\"pte\"> PTE: ${scoreResult}</p>`);\n        });\n        $('#exam-type').on('change', function() {\n            console.log('exam-type');\n            const examType = $(this).val();\n            const scoreResult = $('#score_result');\n            scoreResult.empty();\n            scoreResult.append(`<option value=\"\">Kết quả quy đổi</option>`);\n            for(let key in bangdiem_range){\n                // console.log(key, examType, bangdiem_range[key][examType]);\n                if(bangdiem_range[key][examType]){\n                    console.log('if');\n                    scoreResult.append(`<option value=\"${key}\">${bangdiem_range[key][examType]}</option>`);\n                }\n            }\n        });\n    });\n    </script>\n    \n\n\t\t</div>\n\t\t\t\t\t</div>\n\n\t\n</div>\n\t\t</div>\n\t\t\t\t\n<style>\n#col-816507765 > .col-inner {\n  padding: 0px 0px 0px 0px;\n  margin: 0px 0px 0px 0px;\n  border-radius: 15px;\n}\n@media (min-width:550px) {\n  #col-816507765 > .col-inner {\n    padding: 40px 0px 0px 0px;\n    margin: 40px 0px 40px 0px;\n  }\n}\n</style>\n\t</div>\n\n\t\n</div>\n\t\t</div>\n\n\t\t\n<style>\n#section_1102292115 {\n  padding-top: 0px;\n  padding-bottom: 0px;\n  margin-bottom: 30px;\n}\n#section_1102292115 .section-bg-overlay {\n  background-color: rgb(253, 226, 3);\n}\n</style>\n\t</section>\n\t\n\n\t<section class=\"section\" id=\"section_1200693861\">\n\t\t<div class=\"section-bg fill\" >\n\t\t\t\t\t\t\t\t\t\n\t\t\t\n\n\t\t</div>\n\n\t\t\n\n\t\t<div class=\"section-content relative\">\n\t\t\t\n<div class=\"row\"  id=\"row-615700911\">\n\n\t<div id=\"col-688632361\" class=\"col medium-3 small-12 large-3\"  >\n\t\t\t\t<div class=\"col-inner\"  >\n\t\t\t\n\t\t\t\n\t<div id=\"text-3064230077\" class=\"text number\">\n\t\t\n<p style=\"text-align: center;\"><span style=\"font-size: 400%; color: var(--mau1);\"><strong>13</strong></span></p>\n<p style=\"text-align: center;\">Chi nhánh luyện thi</p>\n\t\t\n<style>\n#text-3064230077 {\n  line-height: 0.75;\n}\n</style>\n\t</div>\n\t\n\t\t</div>\n\t\t\t\t\t</div>\n\n\t\n\n\t<div id=\"col-2129555678\" class=\"col medium-3 small-12 large-3\"  >\n\t\t\t\t<div class=\"col-inner\"  >\n\t\t\t\n\t\t\t\n\t<div id=\"text-3475038445\" class=\"text number\">\n\t\t\n<p style=\"text-align: center;\"><span style=\"font-size: 400%; color: var(--mau1);\"><strong>8.000+</strong></span></p>\n<p style=\"text-align: center;\">Bài thi thực hành</p>\n\t\t\n<style>\n#text-3475038445 {\n  line-height: 0.75;\n}\n</style>\n\t</div>\n\t\n\t\t</div>\n\t\t\t\t\t</div>\n\n\t\n\n\t<div id=\"col-1673593495\" class=\"col medium-3 small-12 large-3\"  >\n\t\t\t\t<div class=\"col-inner\"  >\n\t\t\t\n\t\t\t\n\t<div id=\"text-197062290\" class=\"text number\">\n\t\t\n<p style=\"text-align: center;\"><span style=\"font-size: 400%; color: var(--mau1);\"><strong>100+</strong></span></p>\n<p style=\"text-align: center;\">Giảng viên luyện thi trình độ cao</p>\n\t\t\n<style>\n#text-197062290 {\n  line-height: 0.75;\n}\n</style>\n\t</div>\n\t\n\t\t</div>\n\t\t\t\t\t</div>\n\n\t\n\n\t<div id=\"col-586480989\" class=\"col medium-3 small-12 large-3\"  >\n\t\t\t\t<div class=\"col-inner\"  >\n\t\t\t\n\t\t\t\n\t<div id=\"text-3963428144\" class=\"text number\">\n\t\t\n<p style=\"text-align: center;\"><span style=\"font-size: 400%; color: var(--mau1);\"><strong>60.000+</strong></span></p>\n<p style=\"text-align: center;\">Học viên Việt Nam và Quốc Tế</p>\n\t\t\n<style>\n#text-3963428144 {\n  line-height: 0.75;\n}\n</style>\n\t</div>\n\t\n\t\t</div>\n\t\t\t\t\t</div>\n\n\t\n</div>\n\t\t</div>\n\n\t\t\n<style>\n#section_1200693861 {\n  padding-top: 0px;\n  padding-bottom: 0px;\n}\n</style>\n\t</section>\n\t\n\n\t<section class=\"section pb-0\" id=\"section_1757302815\">\n\t\t<div class=\"section-bg fill\" >\n\t\t\t\t\t\t\t\t\t\n\t\t\t\n\n\t\t</div>\n\n\t\t\n\n\t\t<div class=\"section-content relative\">\n\t\t\t\n<div class=\"row row-collapse align-equal align-right pb-0\" style=\"max-width:1000px\" id=\"row-1237206482\">\n\n\t<div id=\"col-1242884228\" class=\"col small-12 large-12\"  >\n\t\t\t\t<div class=\"col-inner text-center\"  >\n\t\t\t\n\t\t\t\n<h2 style=\"text-align: center; font-size: 170%; font-weight: bold; margin: 0; line-height: 1.2; color: #222;\">Kết hợp học 1 kèm 1 với nền tảng luyện thi của <span style=\"color: var(--mau1);\">PTE Magic</span></h2>\n<p style=\"text-align: center; margin-top: 6px; margin-bottom: 0;\"><em>Học viên khóa DET được học trực tiếp với trainer trong giờ học, làm bài tập sau buổi học, nhận feedback theo từng kỹ năng và theo dõi tiến độ cải thiện. Việc kết hợp giữa giờ học 1 kèm 1, bài tập cá nhân hóa và thi thử giúp học viên biết mình đang yếu ở đâu, cần sửa gì 